# Salin ke .env lalu isi nilainya
# Windows: copy .env.example .env

# Port aplikasi web
PORT=3000

# Secret untuk express-session (ubah ke nilai acak)
SESSION_SECRET=ganti_dengan_string_acak

# Kunci master AES-256-GCM untuk enkripsi StringSession Telegram.
# WAJIB 32 byte dalam hex (64 karakter hex).
# Generate: npm run genkey
TDRIVE_MASTER_KEY=

# Lokasi file database SQLite (opsional)
DB_PATH=./data/tdrive.sqlite

# --- Opsional ---
# Ukuran maksimum satu chunk upload dalam MB (default 1900, harus < 2048).
# TDRIVE_CHUNK_MB=1900

# Batas ukuran upload per file dalam MB (default 10240 = 10 GB).
# TDRIVE_MAX_UPLOAD_MB=10240

# Daftar nomor yang diizinkan login (pisah koma). Kosong = tanpa batasan.
# TDRIVE_ALLOWED_PHONES=+628123456789,+628987654321
