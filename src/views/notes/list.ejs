<%- include('../partials/header') %>

<style>
  /* Donation Banner */
  .donation-banner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px 18px;
    margin-bottom: 20px;
    font-size: 13px;
    border-left: 4px solid var(--accent);
  }
  .donation-links {
    display: flex;
    gap: 12px;
  }
  .donation-links a {
    font-weight: 600;
  }

  .notes-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 28px;
    align-items: start;
    margin-top: 20px;
  }
  
  /* Sidebar Kategori */
  .category-sidebar {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
  }
  .category-sidebar h3 {
    margin-top: 0;
    margin-bottom: 15px;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
    padding-bottom: 8px;
  }
  .category-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .category-item a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    border-radius: 8px;
    color: var(--muted);
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .category-item a:hover {
    background: var(--panel-2);
    color: var(--text);
    text-decoration: none;
  }
  .category-item.active a {
    background: var(--accent);
    color: #fff;
  }
  
  /* Area Catatan */
  .notes-main {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  /* Grid Catatan */
  .note-grid-custom {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 18px;
  }
  .note-card-custom {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 220px;
    position: relative;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .note-card-custom:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.15);
    border-color: var(--accent);
  }
  .note-card-custom .note-open {
    text-decoration: none;
    color: inherit;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .note-card-custom h3 {
    margin: 0;
    font-size: 17px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }
  .note-card-custom .note-snippet {
    margin: 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.5;
    white-space: pre-wrap;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .note-card-custom .note-footer {
    margin-top: 15px;
    border-top: 1px solid var(--border);
    padding-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .note-card-custom .note-meta-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .note-card-custom .note-date {
    font-size: 11px;
    color: var(--muted);
  }
  .note-card-custom .note-cat-tag {
    background: var(--panel-2);
    color: var(--accent);
    border: 1px solid var(--border);
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
  }
  .note-card-custom .note-sync-status {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .dot-status {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .dot-status.synced { background: var(--ok); }
  .dot-status.local { background: var(--danger); }
  .note-card-custom .note-actions {
    display: flex;
    gap: 8px;
    align-items: center;
    justify-content: flex-end;
  }

  /* Modal Styles */
  .modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .modal-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    width: 90%;
    max-width: 480px;
    padding: 24px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  }
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 18px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
  }
  .modal-header h3 {
    margin: 0;
    font-size: 18px;
  }
  .modal-close {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 20px;
    cursor: pointer;
  }
  .hp-field {
    display: none !important;
  }
  
  /* Responsive */
  @media (max-width: 768px) {
    .notes-layout {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- Donation Banner -->
<div class="donation-banner">
  <div>
    🎁 Dukung pengembangan <strong>TDrive &amp; TNote</strong> agar tetap gratis dan open source!
  </div>
  <div class="donation-links">
    <a href="https://tako.id/IsekaiID/gift" target="_blank">🐙 Tako.ID</a>
    <a href="https://trakteer.id/isekai_id/gift" target="_blank">☕ Trakteer</a>
  </div>
</div>

<div class="page-head">
  <div class="breadcrumb">📝 TNote <span class="hint">— catatan E2E cloud</span></div>
  <form method="GET" action="/notes" class="search" onsubmit="event.preventDefault(); performClientSearch(document.getElementById('clientSearchInput').value); return false;">
    <input type="text" id="clientSearchInput" name="q" value="<%= query %>" placeholder="Cari catatan..." oninput="performClientSearch(this.value)" />
    <% if (activeCategory) { %>
      <input type="hidden" name="category" value="<%= activeCategory %>" />
    <% } %>
    <button class="btn small ghost" type="submit">Cari</button>
  </form>
</div>

<% if (error) { %><div class="alert error"><%= error %></div><% } %>
<% if (notice) { %><div class="alert info"><%= notice %></div><% } %>

<div class="toolbar" style="justify-content: space-between; align-items: center;">
  <div>
    <a class="btn" href="/notes/new" style="display: flex; align-items: center; gap: 8px;">
      <span>+</span> Catatan Baru
    </a>
  </div>
  <div class="hint" style="display: flex; align-items: center; gap: 6px;">
    <span>🔒 Terenkripsi E2E</span>
  </div>
</div>

<div class="notes-layout">
  <!-- Sidebar Kategori -->
  <aside class="category-sidebar">
    <h3>Kategori</h3>
    <ul class="category-list">
      <li class="category-item <%= !activeCategory ? 'active' : '' %>">
        <a href="/notes<%= query ? '?q=' + encodeURIComponent(query) : '' %>">
          <span>Semua Catatan</span>
        </a>
      </li>
      <% categories.forEach(function(cat) { %>
        <li class="category-item <%= activeCategory === cat ? 'active' : '' %>">
          <a href="/notes?category=<%= encodeURIComponent(cat) %><%= query ? '&q=' + encodeURIComponent(query) : '' %>">
            <span><%= cat %></span>
          </a>
        </li>
      <% }); %>
    </ul>
  </aside>

  <!-- Area Catatan -->
  <main class="notes-main">
    <% if (query) { %>
      <p class="hint" style="margin: 0;">Hasil pencarian untuk "<strong><%= query %></strong>"<%= activeCategory ? ' di kategori ' + activeCategory : '' %></p>
    <% } else if (activeCategory) { %>
      <p class="hint" style="margin: 0;">Menampilkan catatan dalam kategori "<strong><%= activeCategory %></strong>"</p>
    <% } %>

    <% if (!notes.length) { %>
      <div class="empty card" style="padding: 60px 20px;">
        <p style="font-size: 16px; margin-bottom: 12px;">Belum ada catatan.</p>
        <a class="btn" href="/notes/new">Buat Catatan Pertama</a>
      </div>
    <% } else { %>
      <!-- Container Grid Catatan Dinamis -->
      <div id="notesContainer" class="note-grid-custom">
        <!-- Catatan disuntikkan secara dinamis via Javascript -->
      </div>
      
      <!-- Loader Indicator -->
      <div id="lazyLoaderIndicator" style="text-align: center; padding: 20px; color: var(--muted); display: none; font-size: 13px;">
        🔄 Memuat catatan lainnya...
      </div>
    <% } %>
  </main>
</div>

<script>
  // Inject data catatan yang sudah terdekripsi dari server
  var allNotes = <%- JSON.stringify(notes) %>;
  var sharesMap = <%- JSON.stringify(sharesMap) %>;
  
  var currentIndex = 0;
  var limit = 10;
  var isLoading = false;
  
  function getNoteTypeBadge(type) {
    if (type === 'cmd') return '<span class="note-cat-tag" style="background: #1e1e24; color: #ffb703; border-color: #ffb703;">💻 CMD</span>';
    if (type === 'bash') return '<span class="note-cat-tag" style="background: #0f1c11; color: #39ff14; border-color: #39ff14;">🐧 Bash</span>';
    if (type === 'link') return '<span class="note-cat-tag" style="background: #171c26; color: #2ea6ff; border-color: #2ea6ff;">🔗 Link</span>';
    return '<span class="note-cat-tag" style="background: var(--panel-2); color: var(--accent);">📝 Note</span>';
  }

  function getNoteContentMarkup(note) {
    if (note.note_type === 'link') {
      var url = note.body ? note.body.trim() : '#';
      // Pastikan ada skema protocol
      if (url !== '#' && !/^https?:\/\//i.test(url)) {
        url = 'https://' + url;
      }
      return '<div style="margin-top: 10px; padding: 12px; background: var(--bg); border: 1px dashed var(--border); border-radius: 6px; text-align: center;">' +
             '  <a class="btn small" href="' + url + '" target="_blank" style="display: inline-block; font-weight: 700;">🔗 Buka Tautan Eksternal</a>' +
             '  <p style="margin: 6px 0 0 0; font-size: 11px; color: var(--muted); word-break: break-all; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">' + url + '</p>' +
             '</div>';
    }
    
    // Snippet biasa
    var text = note.body || '';
    var escaped = text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    return '<p class="note-snippet">' + escaped + '</p>';
  }

  function renderNextNotes() {
    if (currentIndex >= allNotes.length) return;
    isLoading = true;
    document.getElementById('lazyLoaderIndicator').style.display = 'block';
    
    var container = document.getElementById('notesContainer');
    var end = Math.min(currentIndex + limit, allNotes.length);
    
    for (var i = currentIndex; i < end; i++) {
      var n = allNotes[i];
      var shareBtnHtml = '';
      if (sharesMap[n.id]) {
        shareBtnHtml = '<button type="button" class="btn small ghost" style="color: var(--ok); border-color: var(--ok); padding: 4px 10px; font-size: 12px;" onclick="showActiveShare(\'' + n.title.replace(/'/g, "\\'") + '\', \'' + sharesMap[n.id] + '\')">🔗 Tautan Aktif</button>';
      } else {
        shareBtnHtml = '<button type="button" class="btn small ghost" style="padding: 4px 10px; font-size: 12px;" onclick="openShareNoteModal(\'' + n.uuid + '\', \'' + n.title.replace(/'/g, "\\'") + '\')">🔗 Bagikan</button>';
      }
      
      var card = document.createElement('div');
      card.className = 'note-card-custom';
      
      var syncDotClass = n.synced ? 'synced' : 'local';
      var formattedDate = new Date(n.updated_at).toLocaleString('id-ID', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
      
      card.innerHTML = 
        '<a class="note-open" href="/notes/' + n.uuid + '">' +
        '  <h3>' + n.title + '</h3>' +
        '</a>' +
        getNoteContentMarkup(n) +
        '<div class="note-footer">' +
        '  <div class="note-meta-line">' +
        '    <div style="display: flex; gap: 6px; align-items: center;">' +
               getNoteTypeBadge(n.note_type) + 
        '      <span class="note-cat-tag">' + (n.category || 'General') + '</span>' +
        '    </div>' +
        '    <div class="note-sync-status" title="' + (n.synced ? 'Tersinkron ke Telegram' : 'Tersimpan lokal') + '">' +
        '      <span class="note-date" style="margin-right: 6px;">' + formattedDate + '</span>' +
        '      <div class="dot-status ' + syncDotClass + '"></div>' +
        '    </div>' +
        '  </div>' +
        '  <div class="note-actions">' +
             shareBtnHtml +
        '    <a class="btn small ghost" href="/notes/' + n.uuid + '" style="padding: 4px 10px; font-size: 12px;">Edit</a>' +
        '    <form method="POST" action="/notes/' + n.uuid + '/delete" onsubmit="return confirm(\'Hapus catatan ini?\');" style="margin: 0;">' +
        '      <input type="hidden" name="_csrf" value="' + '<%= csrfToken %>' + '" />' +
        '      <button class="btn small danger" style="padding: 4px 8px; font-size: 11px;">Hapus</button>' +
        '    </form>' +
        '  </div>' +
        '</div>';
        
      container.appendChild(card);
    }
    
    currentIndex = end;
    isLoading = false;
    document.getElementById('lazyLoaderIndicator').style.display = 'none';
  }

  // Handle client-side live search filter
  function performClientSearch(query) {
    var q = query.toLowerCase().trim();
    var filtered = allNotes.filter(function(n) {
      return (n.title || '').toLowerCase().includes(q) || 
             (n.body || '').toLowerCase().includes(q) || 
             (n.category || '').toLowerCase().includes(q);
    });
    
    // Clear container
    var container = document.getElementById('notesContainer');
    if (container) {
      container.innerHTML = '';
      
      // Render filtered notes (tidak menggunakan lazy load untuk search agar instan)
      filtered.forEach(function(n) {
        var shareBtnHtml = '';
        if (sharesMap[n.id]) {
          shareBtnHtml = '<button type="button" class="btn small ghost" style="color: var(--ok); border-color: var(--ok); padding: 4px 10px; font-size: 12px;" onclick="showActiveShare(\'' + n.title.replace(/'/g, "\\'") + '\', \'' + sharesMap[n.id] + '\')">🔗 Tautan Aktif</button>';
        } else {
          shareBtnHtml = '<button type="button" class="btn small ghost" style="padding: 4px 10px; font-size: 12px;" onclick="openShareNoteModal(\'' + n.uuid + '\', \'' + n.title.replace(/'/g, "\\'") + '\')">🔗 Bagikan</button>';
        }
        
        var card = document.createElement('div');
        card.className = 'note-card-custom';
        var syncDotClass = n.synced ? 'synced' : 'local';
        var formattedDate = new Date(n.updated_at).toLocaleString('id-ID', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
        
        card.innerHTML = 
          '<a class="note-open" href="/notes/' + n.uuid + '">' +
          '  <h3>' + n.title + '</h3>' +
          '</a>' +
          getNoteContentMarkup(n) +
          '<div class="note-footer">' +
          '  <div class="note-meta-line">' +
          '    <div style="display: flex; gap: 6px; align-items: center;">' +
                 getNoteTypeBadge(n.note_type) + 
          '      <span class="note-cat-tag">' + (n.category || 'General') + '</span>' +
          '    </div>' +
          '    <div class="note-sync-status" title="' + (n.synced ? 'Tersinkron ke Telegram' : 'Tersimpan lokal') + '">' +
          '      <span class="note-date" style="margin-right: 6px;">' + formattedDate + '</span>' +
          '      <div class="dot-status ' + syncDotClass + '"></div>' +
          '    </div>' +
          '  </div>' +
          '  <div class="note-actions">' +
               shareBtnHtml +
          '    <a class="btn small ghost" href="/notes/' + n.uuid + '" style="padding: 4px 10px; font-size: 12px;">Edit</a>' +
          '    <form method="POST" action="/notes/' + n.uuid + '/delete" onsubmit="return confirm(\'Hapus catatan ini?\');" style="margin: 0;">' +
          '      <input type="hidden" name="_csrf" value="' + '<%= csrfToken %>' + '" />' +
          '      <button class="btn small danger" style="padding: 4px 8px; font-size: 11px;">Hapus</button>' +
          '    </form>' +
          '  </div>' +
          '</div>';
        container.appendChild(card);
      });
    }
  }

  // Load first set on DOM ready
  window.addEventListener('DOMContentLoaded', function() {
    renderNextNotes();
    
    // Scroll listener for infinite lazy load
    window.addEventListener('scroll', function() {
      if ((window.innerHeight + window.scrollY) >= document.body.offsetHeight - 150) {
        if (!isLoading && currentIndex < allNotes.length) {
          renderNextNotes();
        }
      }
    });
  });
</script>

<!-- ---------------------------------------------------- -->
<!-- MODAL: MEMBAGIKAN CATATAN (SHARED MODAL) -->
<!-- ---------------------------------------------------- -->
<div id="shareModal" class="modal-overlay">
  <div class="modal-card">
    <div class="modal-header">
      <h3 id="shareTitle">Bagikan Catatan</h3>
      <button class="modal-close" onclick="closeShareModal()">&times;</button>
    </div>
    <form method="POST" action="/share/create" class="form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="redirect" id="shareRedirect" />
      <input type="hidden" name="item_type" value="note" />
      <input type="hidden" name="item_uuid" id="shareItemUuid" />

      <!-- Payload terdekripsi dikirim ke server untuk share publik -->
      <input type="hidden" name="shared_title" id="sharedTitle" />
      <input type="hidden" name="shared_body" id="sharedBody" />
      <input type="hidden" name="shared_category" id="sharedCategory" />

      <!-- Honeypot -->
      <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" />

      <p class="hint" style="margin-top: 0;">Membagikan: <strong id="shareItemName" style="color: var(--text);">Catatan</strong></p>

      <label>Proteksi Sandi (Opsional)
        <input type="password" name="password" placeholder="Masukkan kata sandi share" />
      </label>

      <label>Masa Berlaku (Jam, Opsional)
        <input type="number" name="expires_in_hours" min="1" placeholder="Mis. 24 (kosong = selamanya)" />
      </label>

      <label>Batas Maksimal Dibuka (Kali, Opsional)
        <input type="number" name="max_views" min="1" placeholder="Mis. 5 (kosong = tak terbatas)" />
      </label>

      <div style="margin-top: 15px; display: flex; gap: 10px;">
        <button class="btn" type="submit" style="flex: 1;">Buat Tautan Berbagi</button>
        <button class="btn ghost" type="button" onclick="closeShareModal()">Batal</button>
      </div>
    </form>
  </div>
</div>

<div id="activeShareModal" class="modal-overlay">
  <div class="modal-card">
    <div class="modal-header">
      <h3>🔗 Tautan Berbagi Catatan</h3>
      <button class="modal-close" onclick="closeActiveShareModal()">&times;</button>
    </div>
    <div class="form">
      <p class="hint" style="margin-top: 0;">Item: <strong id="activeShareItemName" style="color: var(--text);">Catatan</strong></p>
      
      <label>Tautan Publik Anda
        <input type="text" id="activeShareUrl" readonly onclick="this.select();" style="font-family: monospace; font-size: 13px;" />
      </label>
      
      <!-- Opsi Tautan Auto-Bypass (Muncul hanya jika share dilindungi password) -->
      <div id="bypassLinkSection" style="margin-top: 14px; display: none;">
        <label style="color: var(--accent); font-weight: 700;">🔗 Tautan Auto-Bypass (Include Sandi Base32)</label>
        <input type="text" id="activeShareBypassUrl" readonly onclick="this.select();" style="font-family: monospace; font-size: 13px; border-color: var(--accent);" />
        <p class="hint" style="margin: 4px 0 0 0; font-size: 11px; color: var(--muted);">Tautan ini menyertakan password ter-encode Base32 sehingga penerima tidak perlu mengetikkan password lagi.</p>
      </div>
      
      <!-- Opsi TShort Shortlink -->
      <div id="tshortLinkSection" style="margin-top: 14px; display: none;">
        <label style="color: #ffb703; font-weight: 700;">⚡ Tautan Pendek TShort</label>
        <input type="text" id="activeShareShortUrl" readonly onclick="this.select();" style="font-family: monospace; font-size: 13px; border-color: #ffb703;" />
        <p class="hint" style="margin: 4px 0 0 0; font-size: 11px; color: var(--muted);">Shortlink instan TShort yang aman dan ringkas.</p>
      </div>
      
      <div style="display: flex; gap: 10px; margin-top: 18px; flex-wrap: wrap;">
        <button type="button" class="btn" onclick="copyShareUrl()" style="flex: 1; min-width: 120px;">Salin Tautan</button>
        <button type="button" id="copyBypassBtn" class="btn secondary" onclick="copyShareBypassUrl()" style="flex: 1; min-width: 120px; display: none;">Salin Tautan + Sandi</button>
        
        <form method="POST" action="" id="revokeShareForm" style="flex: 1; display: flex; margin: 0; min-width: 120px;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <input type="hidden" name="redirect" id="revokeRedirect" />
          <!-- Honeypot -->
          <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" />
          <button type="submit" class="btn danger" style="width: 100%;">Tarik Tautan</button>
        </form>
      </div>
    </div>
  </div>
</div>
<!-- ---------------------------------------------------- -->
<!-- MODAL: KELOLA WORKSPACE KOLABORASI -->
<!-- ---------------------------------------------------- -->
<div id="workspaceModal" class="modal-overlay">
  <div class="modal-card">
    <div class="modal-header">
      <h3>👥 Undang Kolaborator</h3>
      <button class="modal-close" onclick="closeWorkspaceModal()">&times;</button>
    </div>
    <form method="POST" action="/workspace/share-workspace" class="form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="redirect" id="workspaceRedirect" />
      <input type="hidden" name="item_type" id="workspaceItemType" />
      <input type="hidden" name="item_uuid" id="workspaceItemUuid" />
      <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" />

      <p class="hint" style="margin-top: 0;">Mengundang untuk: <strong id="workspaceItemName" style="color: var(--text);">Catatan</strong></p>

      <label>Nomor Telepon Rekan (Format Internasional)
        <input type="text" name="target_phone" placeholder="Mis. +62812345678" required />
      </label>

      <label>Hak Akses
        <select name="permission" style="width: 100%; padding: 10px 12px; margin-top: 6px; border-radius: 6px; background: var(--panel-2); color: var(--text); border: 1px solid var(--border); font-size: 14px; outline: none; box-sizing: border-box; cursor: pointer;">
          <option value="read">Baca Saja (Read)</option>
          <option value="write">Tulis &amp; Baca (Write)</option>
        </select>
      </label>

      <div style="margin-top: 15px; display: flex; gap: 10px;">
        <button class="btn" type="submit" style="flex: 1;">Undang</button>
        <button class="btn ghost" type="button" onclick="closeWorkspaceModal()">Batal</button>
      </div>
    </form>
  </div>
</div>

<script>
  var currentUrl = window.location.pathname + window.location.search;

  function openShareNoteModal(uuid, name) {
    document.getElementById('shareItemUuid').value = uuid;
    document.getElementById('shareItemName').innerText = name;
    
    // Cari data catatan terdekripsi dari array allNotes di memori
    var noteObj = allNotes.find(function(n) { return n.uuid === uuid; });
    var title = noteObj ? noteObj.title : name;
    var body = noteObj ? noteObj.body : '';
    var category = noteObj ? noteObj.category : 'General';

    document.getElementById('sharedTitle').value = title;
    document.getElementById('sharedBody').value = body;
    document.getElementById('sharedCategory').value = category;

    document.getElementById('shareRedirect').value = currentUrl;
    document.getElementById('shareModal').style.display = 'flex';
  }

  function closeShareModal() {
    document.getElementById('shareModal').style.display = 'none';
  }

  // Base32 encoder helper (RFC 4648)
  function base32Encode(str) {
    var alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567";
    var bytes = [];
    for (var i = 0; i < str.length; i++) {
      bytes.push(str.charCodeAt(i));
    }
    
    var result = "";
    var val = 0;
    var count = 0;
    for (var i = 0; i < bytes.length; i++) {
      val = (val << 8) | bytes[i];
      count += 8;
      while (count >= 5) {
        result += alphabet.charAt((val >> (count - 5)) & 31);
        count -= 5;
      }
    }
    if (count > 0) {
      result += alphabet.charAt((val << (5 - count)) & 31);
    }
    return result;
  }

  function showActiveShare(name, shareUuid, plainPassword) {
    var fullUrl = window.location.origin + '/share/' + shareUuid;
    document.getElementById('activeShareItemName').innerText = name;
    document.getElementById('activeShareUrl').value = fullUrl;
    
    var bypassSection = document.getElementById('bypassLinkSection');
    var copyBypassBtn = document.getElementById('copyBypassBtn');
    
    var finalUrlForShort = fullUrl;
    if (plainPassword) {
      var encoded = base32Encode(plainPassword);
      var bypassUrl = fullUrl + '?pass=' + encoded;
      document.getElementById('activeShareBypassUrl').value = bypassUrl;
      bypassSection.style.display = 'block';
      copyBypassBtn.style.display = 'inline-block';
      finalUrlForShort = bypassUrl;
    } else {
      bypassSection.style.display = 'none';
      copyBypassBtn.style.display = 'none';
    }
    
    // Reset shortcode section
    document.getElementById('tshortLinkSection').style.display = 'none';
    
    // Fetch TShort shortcode
    fetch(window.location.origin + '/share/' + shareUuid + '/shortcode-data')
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.success && data.short_code) {
          var tshortUrl = window.location.origin + '/s/' + data.short_code;
          document.getElementById('activeShareShortUrl').value = tshortUrl;
          document.getElementById('tshortLinkSection').style.display = 'block';
        }
      })
      .catch(function(err) { console.error("Gagal memuat TShort code:", err); });

    var form = document.getElementById('revokeShareForm');
    form.action = '/share/' + shareUuid + '/revoke';
    document.getElementById('revokeRedirect').value = currentUrl;

    document.getElementById('activeShareModal').style.display = 'flex';
  }

  function closeActiveShareModal() {
    document.getElementById('activeShareModal').style.display = 'none';
  }

  function copyShareUrl() {
    var input = document.getElementById('activeShareUrl');
    input.select();
    document.execCommand('copy');
    alert('Tautan berhasil disalin ke clipboard!');
  }

  function copyShareBypassUrl() {
    var input = document.getElementById('activeShareBypassUrl');
    input.select();
    document.execCommand('copy');
    alert('Tautan Auto-Bypass (termasuk sandi) berhasil disalin ke clipboard!');
  }

  // Deteksi share yang baru saja dibuat berpassword
  window.addEventListener('DOMContentLoaded', function() {
    var urlParams = new URLSearchParams(window.location.search);
    var createdUuid = urlParams.get('created_share_uuid');
    var createdPass = urlParams.get('created_pass');
    var createdName = urlParams.get('created_name');
    if (createdUuid && createdPass) {
      showActiveShare(createdName || 'Catatan Berbagi', createdUuid, createdPass);
    }
  });

  // --- LOGIKA WORKSPACE MODAL ---
  function openWorkspaceModal(type, uuid, name) {
    document.getElementById('workspaceItemType').value = type;
    document.getElementById('workspaceItemUuid').value = uuid;
    document.getElementById('workspaceItemName').innerText = name;
    document.getElementById('workspaceRedirect').value = currentUrl;
    document.getElementById('workspaceModal').style.display = 'flex';
  }

  function closeWorkspaceModal() {
    document.getElementById('workspaceModal').style.display = 'none';
  }

  // --- LOGIKA PENCARIAN CLIENT-SIDE (ZERO-KNOWLEDGE) ---
  function performClientSearch(queryText) {
    var q = queryText.toLowerCase().trim();
    var cards = document.querySelectorAll('.note-card-custom');
    var matchCount = 0;

    cards.forEach(function(card) {
      var title = card.querySelector('h3').innerText.toLowerCase();
      var snippet = card.querySelector('.note-snippet').innerText.toLowerCase();
      var category = card.querySelector('.note-cat-tag').innerText.toLowerCase();

      if (title.includes(q) || snippet.includes(q) || category.includes(q)) {
        card.style.display = 'flex';
        matchCount++;
      } else {
        card.style.display = 'none';
      }
    });

    // Tampilkan/sembunyikan notice jika tidak ada hasil
    var emptyDiv = document.querySelector('.empty.card');
    if (cards.length > 0) {
      if (matchCount === 0) {
        if (!emptyDiv) {
          var container = document.querySelector('.note-grid-custom');
          var notice = document.createElement('div');
          notice.className = 'empty-search-notice hint';
          notice.style.textAlign = 'center';
          notice.style.padding = '40px';
          notice.style.width = '100%';
          notice.innerText = 'Tidak ada catatan yang cocok dengan pencarian Anda.';
          container.appendChild(notice);
        }
      } else {
        var existingNotice = document.querySelector('.empty-search-notice');
        if (existingNotice) existingNotice.remove();
      }
    }
  }
</script>

