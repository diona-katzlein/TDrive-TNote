<!-- Form tersembunyi untuk rename (diisi via prompt) -->
<form method="POST" id="renameFileForm" style="display:none">
  <!-- Honeypot -->
  <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" />
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <input type="hidden" name="name" id="renameFileName" />
</form>
<form method="POST" id="renameFolderForm" style="display:none">
  <!-- Honeypot -->
  <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" />
  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
  <input type="hidden" name="name" id="renameFolderName" />
</form>

<script>
  // Setup URLs
  var currentUrl = window.location.pathname + window.location.search;

  function renameFile(uuid, current) {
    var name = window.prompt('Nama baru untuk file:', current);
    if (name && name.trim()) {
      var f = document.getElementById('renameFileForm');
      f.action = '/drive/file/' + uuid + '/rename';
      document.getElementById('renameFileName').value = name.trim();
      f.submit();
    }
  }
  
  function renameFolder(uuid, current) {
    var name = window.prompt('Nama baru untuk folder:', current);
    if (name && name.trim()) {
      var f = document.getElementById('renameFolderForm');
      f.action = '/folders/' + uuid + '/rename';
      document.getElementById('renameFolderName').value = name.trim();
      f.submit();
    }
  }

  // --- LOGIKA MODAL SHARING ---
  function openShareModal(type, uuid, name) {
    document.getElementById('shareItemType').value = type;
    document.getElementById('shareItemUuid').value = uuid;
    document.getElementById('shareItemName').innerText = name;
    document.getElementById('shareRedirect').value = currentUrl;
    document.getElementById('shareModal').style.display = 'flex';
  }

  function closeShareModal() {
    document.getElementById('shareModal').style.display = 'none';
  }

  // Base32 encoder helper (RFC 4648)
  function base32Encode(str) {
    var alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567";
    var bytes = [];
    for (var i = 0; i < str.length; i++) {
      bytes.push(str.charCodeAt(i));
    }
    
    var result = "";
    var val = 0;
    var count = 0;
    for (var i = 0; i < bytes.length; i++) {
      val = (val << 8) | bytes[i];
      count += 8;
      while (count >= 5) {
        result += alphabet.charAt((val >> (count - 5)) & 31);
        count -= 5;
      }
    }
    if (count > 0) {
      result += alphabet.charAt((val << (5 - count)) & 31);
    }
    return result;
  }

  function showActiveShare(name, shareUuid, plainPassword, itemType, itemUuid) {
    var fullUrl = window.location.origin + '/share/' + shareUuid;
    document.getElementById('activeShareItemName').innerText = name;
    document.getElementById('activeShareUrl').value = fullUrl;
    
    var bypassSection = document.getElementById('bypassLinkSection');
    var copyBypassBtn = document.getElementById('copyBypassBtn');
    
    var finalShareUrl = fullUrl;
    if (plainPassword) {
      var encoded = base32Encode(plainPassword);
      var bypassUrl = fullUrl + '?pass=' + encoded;
      document.getElementById('activeShareBypassUrl').value = bypassUrl;
      bypassSection.style.display = 'block';
      copyBypassBtn.style.display = 'inline-block';
      finalShareUrl = bypassUrl; // Gunakan link bypass untuk Instant View
    } else {
      bypassSection.style.display = 'none';
      copyBypassBtn.style.display = 'none';
    }
    
    // Sembunyikan default shortlink section
    document.getElementById('telegramShortlinkSection').style.display = 'none';
    document.getElementById('telegramIvSection').style.display = 'none';

    // Jika item adalah file, ambil data chunk untuk shortlink Telegram
    if (itemType === 'file' && itemUuid) {
      fetch('/drive/file/' + itemUuid + '/link-data')
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.success && data.message_id) {
            var peerStr = data.peer || 'me';
            var cleanChannelId = '';
            
            // Format t.me/c/ hanya bekerja untuk channel/supergroup.
            // ID channel di database diawali dengan -100 (mis. -1002082218882)
            var isPublicChannel = false;
            var channelUsername = '';
            
            try {
              var parsedPeer = JSON.parse(peerStr);
              if (parsedPeer.username) {
                isPublicChannel = true;
                channelUsername = parsedPeer.username;
              } else {
                var rawId = String(parsedPeer.channelId || parsedPeer.chatId || '');
                if (rawId.startsWith('-100')) {
                  cleanChannelId = rawId.substring(4);
                } else if (rawId.startsWith('-')) {
                  cleanChannelId = rawId.substring(1);
                } else {
                  cleanChannelId = rawId;
                }
              }
            } catch (_) {
              if (peerStr.startsWith('@')) {
                isPublicChannel = true;
                channelUsername = peerStr.substring(1);
              } else if (peerStr.startsWith('-100')) {
                cleanChannelId = peerStr.substring(4);
              } else if (peerStr.startsWith('-')) {
                cleanChannelId = peerStr.substring(1);
              } else {
                cleanChannelId = peerStr;
              }
            }

            if (isPublicChannel && channelUsername) {
              var tmeUrl = 'https://t.me/' + channelUsername + '/' + data.message_id;
              document.getElementById('activeShareTelegramUrl').value = tmeUrl;
              document.getElementById('telegramShortlinkSection').style.display = 'block';
            } else if (cleanChannelId && cleanChannelId !== 'me' && cleanChannelId !== 'Saved Messages' && cleanChannelId !== 'undefined') {
              var tmeUrl = 'https://t.me/c/' + cleanChannelId + '/' + data.message_id;
              document.getElementById('activeShareTelegramUrl').value = tmeUrl;
              document.getElementById('telegramShortlinkSection').style.display = 'block';
            } else {
              // Fallback Saved Messages / Private chat info
              document.getElementById('activeShareTelegramUrl').value = "Tidak tersedia (Saved Messages bersifat privat)";
              document.getElementById('telegramShortlinkSection').style.display = 'block';
            }
          }
        })
        .catch(function(err) { console.error('Gagal mengambil shortlink data:', err); });
        
      // Selalu tampilkan opsi Instant View t.me/iv dengan format Telegram instant view
      var tmeIvUrl = 'https://t.me/iv?url=' + encodeURIComponent(finalShareUrl) + '&rhash=1234567890';
      document.getElementById('activeShareIvUrl').value = tmeIvUrl;
      document.getElementById('telegramIvSection').style.display = 'block';
    }
    
    // Reset shortcode TShort section
    document.getElementById('tshortLinkSection').style.display = 'none';
    document.getElementById('copyShortBtn').style.display = 'none';

    // Fetch TShort shortcode
    fetch(window.location.origin + '/share/' + shareUuid + '/shortcode-data')
      .then(function(res) { return res.json(); })
      .then(function(data) {
        if (data.success && data.short_code) {
          var tshortUrl = window.location.origin + '/s/' + data.short_code;
          document.getElementById('activeShareShortUrl').value = tshortUrl;
          document.getElementById('tshortLinkSection').style.display = 'block';
          document.getElementById('copyShortBtn').style.display = 'inline-block';
        }
      })
      .catch(function(err) { console.error("Gagal memuat TShort code:", err); });
    
    // Setup revoke form
    var form = document.getElementById('revokeShareForm');
    form.action = '/share/' + shareUuid + '/revoke';
    document.getElementById('revokeRedirect').value = currentUrl;

    document.getElementById('activeShareModal').style.display = 'flex';
  }

  function closeActiveShareModal() {
    document.getElementById('activeShareModal').style.display = 'none';
