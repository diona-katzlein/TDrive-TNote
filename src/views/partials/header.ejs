<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'TDrive & TNote' %> · TDrive</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <header class="topbar">
    <a class="brand" href="/" style="display: flex; align-items: center;"><img src="/logo.svg" alt="TDrive Logo" style="height: 36px;" /></a>
    <nav class="nav-links">
      <a class="nav-link" href="/drive">TDrive</a>
      <a class="nav-link" href="/notes">TNote</a>
      <a class="nav-link" href="/shortlink">TShort</a>
      <!-- <a class="nav-link" href="/workspace/shared-with-me">Workspace</a> -->
      <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <a class="nav-link" href="/accounts">Accounts</a>
        <a class="nav-link" href="/backup">Backup</a>
      <% } %>
      <a class="nav-link" href="/profile">Profile</a>
    </nav>
    <div class="account-switch">
      <% if (typeof accounts !== 'undefined' && accounts.length) { %>
        <form method="POST" action="" id="switchForm">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <select onchange="if(this.value){document.getElementById('switchForm').action='/accounts/'+this.value+'/activate';document.getElementById('switchForm').submit();}">
            <% accounts.forEach(function(a){ %>
              <option value="<%= a.id %>" <%= (activeAccount && activeAccount.id === a.id) ? 'selected' : '' %>>
                <%= a.label || a.phone %>
              </option>
            <% }); %>
          </select>
        </form>
      <% } else { %>
        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
          <a class="btn small" href="/accounts/add">+ Add Account</a>
        <% } %>
      <% } %>
    </div>
  </header>
  <main class="container">
