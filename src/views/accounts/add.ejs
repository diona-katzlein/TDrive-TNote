<%- include('../partials/header') %>

<div class="page-head">
  <h1>Tambah Akun Telegram</h1>
</div>

<% if (error) { %><div class="alert error"><%= error %></div><% } %>

<div class="card narrow">
  <p class="hint">
    Tambahkan akun Telegram lain sebagai drive. Cukup masukkan nomor telepon;
    kode OTP akan dikirim ke Telegram. Anda akan diminta membuat label setelahnya.
  </p>
  <form method="POST" action="/accounts/send-code" class="form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>Nomor Telepon
      <input type="text" name="phone" required placeholder="+62812xxxxxxx" autofocus />
    </label>
    <button class="btn" type="submit">Kirim Kode OTP</button>
  </form>
</div>

<%- include('../partials/footer') %>
