<%- include('../partials/auth-header') %>

<div class="auth-card card narrow">
  <h1>Masuk ke TDrive</h1>
  <p class="hint">Login menggunakan akun Telegram Anda. Cukup masukkan nomor telepon,
    lalu masukkan kode OTP yang dikirim ke Telegram.
  </p>

  <% if (error) { %><div class="alert error"><%= error %></div><% } %>

  <form method="POST" action="/login/check-phone" class="form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>Nomor Telepon
      <input type="text" name="phone" required placeholder="+62812xxxxxxx" autofocus />
    </label>
    <button class="btn" type="submit">Lanjut</button>
  </form>
  
  <div style="margin-top: 20px; text-align: center; font-size: 13px;">
    <a href="/guide" style="color: var(--accent); font-weight: 600;">📖 Baca Panduan Penggunaan</a>
  </div>
</div>

<%- include('../partials/footer') %>
