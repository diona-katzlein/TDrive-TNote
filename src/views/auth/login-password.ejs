<%- include('../partials/auth-header') %>

<div class="auth-card card narrow">
  <h1>Masuk dengan Sandi</h1>
  <p class="hint">Nomor Anda (<strong><%= phone %></strong>) sudah terdaftar. Masukkan kata sandi atau PIN sistem Anda untuk masuk tanpa OTP Telegram.</p>

  <% if (error) { %><div class="alert error"><%= error %></div><% } %>

  <form method="POST" action="/login/verify-password" class="form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="phone" value="<%= phone %>" />
    <label>Kata Sandi / PIN Sistem
      <div style="position: relative; display: flex; align-items: center; margin-top: 6px;">
        <input type="password" name="password" id="password-input" required placeholder="Masukkan Sandi/PIN" autofocus style="width: 100%; padding-right: 40px;" />
        <button type="button" onclick="togglePassword()" style="position: absolute; right: 12px; background: none; border: none; color: var(--muted); cursor: pointer; font-size: 18px; outline: none;" id="toggle-btn" title="Lihat/Sembunyikan Sandi">👁️</button>
      </div>
    </label>
    <button class="btn" type="submit">Masuk</button>
  </form>

  <div style="margin-top: 20px; text-align: center;">
    <form method="POST" action="/login/send-otp-forced" style="display: inline;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="phone" value="<%= phone %>" />
      <button type="submit" class="btn ghost small" style="background: none; border: none; color: var(--accent); cursor: pointer; text-decoration: underline;">
        Masuk menggunakan OTP Telegram
      </button>
    </form>
  </div>
</div>

<script>
  function togglePassword() {
    var input = document.getElementById('password-input');
    var btn = document.getElementById('toggle-btn');
    if (input.type === 'password') {
      input.type = 'text';
      btn.innerText = '🙈';
    } else {
      input.type = 'password';
      btn.innerText = '👁️';
    }
  }
</script>

<%- include('../partials/footer') %>
