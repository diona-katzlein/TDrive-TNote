<%- include('partials/auth-header') %>

<div class="auth-card card narrow" style="margin: 60px auto; text-align: center; border-color: var(--danger);">
  <h1 style="font-size: 50px; margin: 0; color: var(--danger);">⚠️</h1>
  <h2 style="margin-top: 10px; font-size: 24px; font-weight: 800;">413 · Payload Terlalu Besar</h2>
  
  <div style="background: var(--bg); border: 1px solid var(--border); padding: 18px; border-radius: 8px; margin: 20px 0; text-align: left;">
    <p style="margin: 0; font-size: 14px; line-height: 1.6; color: var(--text);">
      <%= error %>
    </p>
    <p style="margin: 10px 0 0 0; font-size: 12px; color: var(--muted);">
      Tips: Jika Anda sedang mengunggah atau membuat catatan yang sangat panjang, silakan pisahkan data catatan tersebut menjadi beberapa berkas catatan yang lebih kecil (maksimal 3500 karakter per catatan) agar bisa disinkronkan ke Telegram dengan lancar.
    </p>
  </div>

  <div style="display: flex; gap: 12px; margin-top: 25px;">
    <button class="btn" onclick="window.history.back()" style="flex: 1;">⬅ Kembali</button>
    <a class="btn ghost" href="/notes" style="flex: 1;">Ke TNote</a>
  </div>
</div>

<%- include('partials/footer') %>
