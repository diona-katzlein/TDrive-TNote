<%- include('../partials/auth-header') %>

<style>
  .note-view-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 30px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    margin: 20px auto;
    max-width: 720px;
  }
  .note-view-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 15px;
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  .note-view-header h2 {
    margin: 0;
    font-size: 24px;
    color: var(--text);
  }
  .note-view-body {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
    white-space: pre-wrap;
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    min-height: 250px;
  }
  .note-view-footer {
    margin-top: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--muted);
  }
  .note-cat {
    background: var(--panel-2);
    color: var(--accent);
    border: 1px solid var(--border);
    padding: 2px 10px;
    border-radius: 20px;
    font-weight: 600;
  }
</style>

<div class="note-view-card">
  <div class="note-view-header">
    <h2>📝 <%= note.title %></h2>
    <span class="note-cat"><%= note.category || 'General' %></span>
  </div>
  
  <div class="note-view-body"><%= note.body %></div>
  
  <div class="note-view-footer">
    <span>Diperbarui pada: <%= formatDate(note.updated_at) %></span>
    <span style="display: flex; align-items: center; gap: 4px;">🔒 Catatan Terenkripsi E2E</span>
  </div>
</div>

<%- include('../partials/footer') %>
