<%- include('../partials/auth-header') %>

<div class="auth-card card narrow" style="margin: 40px auto; text-align: center;">
  <h1>🔒 Tautan Dilindungi</h1>
  <p class="hint" style="margin-bottom: 24px;">Tautan berbagi publik ini dilindungi oleh kata sandi. Silakan masukkan kata sandi untuk mengakses berkas atau catatan ini.</p>

  <% if (error) { %><div class="alert error"><%= error %></div><% } %>

  <form method="POST" action="/share/<%= uuid %>/unlock" class="form" style="text-align: left;">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label>Kata Sandi Share
      <div style="position: relative; display: flex; align-items: center; margin-top: 6px;">
        <input type="password" name="password" id="password-input" required placeholder="Masukkan kata sandi" autofocus style="width: 100%; padding-right: 40px;" />
        <button type="button" onclick="togglePassword()" style="position: absolute; right: 12px; background: none; border: none; color: var(--muted); cursor: pointer; font-size: 18px; outline: none;" id="toggle-btn">👁️</button>
      </div>
    </label>
    <button class="btn" style="margin-top: 10px; width: 100%;" type="submit">Buka Akses</button>
  </form>
</div>

<script>
  function togglePassword() {
    var input = document.getElementById('password-input');
    var btn = document.getElementById('toggle-btn');
    if (input.type === 'password') {
      input.type = 'text';
      btn.innerText = '🙈';
    } else {
      input.type = 'password';
      btn.innerText = '👁️';
    }
  }

  // Base32 Decoder Helper (RFC 4648)
  function base32Decode(str) {
    str = str.replace(/=+$/, "").toUpperCase();
    var alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ234567";
    var result = "";
    var val = 0;
    var count = 0;
    
    for (var i = 0; i < str.length; i++) {
      var idx = alphabet.indexOf(str.charAt(i));
      if (idx === -1) continue;
      
      val = (val << 5) | idx;
      count += 5;
      if (count >= 8) {
        result += String.fromCharCode((val >> (count - 8)) & 255);
        count -= 8;
      }
    }
    return result;
  }

  // Auto-Submit if 'pass' query exists
  window.addEventListener('DOMContentLoaded', function() {
    var urlParams = new URLSearchParams(window.location.search);
    var pass = urlParams.get('pass');
    if (pass) {
      try {
        var plain = base32Decode(pass);
        if (plain) {
          document.getElementById('password-input').value = plain;
          // Trigger submit form
          var form = document.querySelector('form');
          if (form) {
            form.submit();
          }
        }
      } catch (err) {
        console.error("Auto bypass failed:", err);
      }
    }
  });
</script>

<%- include('../partials/footer') %>
